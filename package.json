{
  "name": "millrace",
  "version": "0.0.20",
  "description": "Git-friendly Kanban work items as INI files under tasks/ — local server and web UI",
  "repository": {
    "type": "git",
    "url": "https://github.com/Steve-Fenton/millrace"
  },
  "type": "module",
  "bin": {
    "millrace": "server.js"
  },
  "files": [
    "server.js",
    "index.html",
    "favicon.ico",
    "assets",
    "admin",
    "charts",
    "complete",
    "preferences"
  ],
  "scripts": {
    "start": "node server.js 7713",
    "test": "NODE_OPTIONS=--experimental-vm-modules c8 cucumber-js",
    "test:cucumber": "cucumber-js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "kanban",
    "millrace",
    "tasks",
    "ini",
    "git"
  ],
  "c8": {
    "include": [
      "assets/js/**/*.js",
      "server.js"
    ],
    "reporter": [
      "text",
      "html"
    ]
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "c8": "^11.0.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2"
  }
}

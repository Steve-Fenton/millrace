{
  "name": "millrace",
  "version": "0.0.4",
  "description": "Git-friendly Kanban work items as INI files under tasks/ — local server and web UI",
  "repository": {
    "type": "git",
    "url": "https://github.com/Steve-Fenton/millrace"
  },
  "type": "module",
  "bin": {
    "millrace": "server.js"
  },
  "files": [
    "server.js",
    "index.html",
    "assets",
    "admin",
    "charts",
    "complete"
  ],
  "scripts": {
    "start": "FLOW_GIT_AUTO_COMMIT=1 node server.js 7713",
    "start:no-commit": "node server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "kanban",
    "millrace",
    "tasks",
    "ini",
    "git"
  ],
  "dependencies": {
    "express": "^4.21.2"
  }
}

{
  "name": "millrace",
  "version": "0.0.49",
  "description": "Git-friendly Kanban work items as INI files under tasks/ — local server and web UI",
  "repository": {
    "type": "git",
    "url": "https://github.com/Steve-Fenton/millrace"
  },
  "type": "module",
  "bin": {
    "millrace": "server.js"
  },
  "files": [
    "server.js",
    "server",
    "index.html",
    "favicon.ico",
    "assets",
    "admin",
    "charts",
    "complete",
    "preferences",
    "users"
  ],
  "scripts": {
    "sync-docs": "node scripts/sync-docs-version.mjs",
    "reset-demo": "node scripts/reset-demo-board.mjs",
    "prepublishOnly": "node scripts/sync-docs-version.mjs",
    "version": "node scripts/sync-docs-version.mjs",
    "start": "node server.js 7713",
    "test": "MILLRACE_TESTS_DISABLE_REGISTRY_FETCH=1 NODE_OPTIONS=--experimental-vm-modules c8 cucumber-js",
    "test:cucumber": "MILLRACE_TESTS_DISABLE_REGISTRY_FETCH=1 cucumber-js",
    "screenshots": "node scripts/reset-demo-board.mjs && playwright test",
    "screenshots:install": "playwright install chromium"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "kanban",
    "millrace",
    "tasks",
    "ini",
    "git"
  ],
  "c8": {
    "include": [
      "assets/js/**/*.js",
      "server.js",
      "server/**/*.js"
    ],
    "reporter": [
      "text",
      "html"
    ]
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@cucumber/cucumber": "^11.2.0",
    "c8": "^11.0.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2"
  }
}
